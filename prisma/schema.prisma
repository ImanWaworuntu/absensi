// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  guru_mapel
  guru_piket
  guru_dual
}

enum Hari {
  Senin
  Selasa
  Rabu
  Kamis
  Jumat
  Sabtu
}

enum StatusKehadiran {
  hadir
  sakit
  izin
  alfa
}

model User {
  id              String   @id @default(cuid()) // UID dari Firebase Authentication
  username        String   @unique @db.VarChar(50)
  email           String   @unique @db.VarChar(100)
  password        String   @db.VarChar(255)
  nama_lengkap    String   @db.VarChar(150)
  role            Role
  created_at      DateTime @default(now())

  // Relations
  jadwal_mengajar JadwalMengajar[]
  presensi_piket  PresensiPiket[]
  presensi_mapel  PresensiMapel[] @relation("PresensiMapel_Guru")
  dibantu_absen   PresensiMapel[] @relation("PresensiMapel_Piket")
  
  @@map("users")
}

model JadwalMengajar {
  id              Int      @id @default(autoincrement())
  guru_id         String
  mata_pelajaran  String   @db.VarChar(100)
  hari            Hari
  jam_ke          Int[]
  kelas           String   @db.VarChar(20)

  guru            User     @relation(fields: [guru_id], references: [id], onDelete: Cascade)

  @@map("jadwal_mengajar")
}

model PresensiPiket {
  id                Int      @id @default(autoincrement())
  guru_id           String
  tanggal           DateTime @db.Date
  jam_datang        DateTime @db.Time
  jam_pulang        DateTime? @db.Time
  foto_datang_url   String   @db.VarChar(255)
  foto_pulang_url   String?  @db.VarChar(255)
  latitude_datang   Decimal  @db.Decimal(10, 8)
  longitude_datang  Decimal  @db.Decimal(11, 8)
  ip_address        String   @db.VarChar(45)

  guru              User     @relation(fields: [guru_id], references: [id], onDelete: Cascade)

  @@map("presensi_piket")
}

model PresensiMapel {
  id                      Int      @id @default(autoincrement())
  guru_id                 String
  tanggal                 DateTime @db.Date
  jam_absen               DateTime @db.Time
  jam_ke                  Int[]
  status_kehadiran        StatusKehadiran @default(hadir)
  foto_url                String?  @db.VarChar(255)
  latitude                Decimal  @db.Decimal(10, 8)
  longitude               Decimal  @db.Decimal(11, 8)
  diabsenkan_oleh_piket_id String?
  ip_address              String   @db.VarChar(45)

  guru                    User     @relation("PresensiMapel_Guru", fields: [guru_id], references: [id], onDelete: Cascade)
  piket                   User?    @relation("PresensiMapel_Piket", fields: [diabsenkan_oleh_piket_id], references: [id], onDelete: SetNull)

  @@map("presensi_mapel")
}
